{
  "expo": {
    "name": "FitGO",
    "slug": "fitgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "fitgo",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0F14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fitgo.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan food barcodes and take progress photos",
        "NSMicrophoneUsageDescription": "Use voice to log food and talk with your AI coach",
        "NSPhotoLibraryUsageDescription": "Access your photo library for progress photos"
      }
    },
    "android": {
      "package": "com.fitgo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0F14"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "standalone",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-barcode-scanner",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FitGO to access your camera to scan food barcodes and take progress photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7C5CFC"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow FitGO to access your microphone to log food and talk with your AI coach."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
